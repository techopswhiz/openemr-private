# LLM — xAI Grok (OpenAI-compatible)
XAI_API_KEY=xai-your-key-here
XAI_MODEL=grok-3-mini-fast

# OpenEMR REST API (optional — runs in demo mode without these)
OPENEMR_BASE_URL=http://localhost:8300
OPENEMR_CLIENT_ID=
OPENEMR_CLIENT_SECRET=
OPENEMR_USERNAME=admin
OPENEMR_PASSWORD=pass

# LangSmith observability
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=ls-your-key-here
LANGCHAIN_PROJECT=openemr-agent

# App
HOST=0.0.0.0
PORT=8080
