# OpenEMR Production Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# --- LLM API Key ---
# Required for the clinical agent to call the AI model
XAI_API_KEY=

# --- OAuth2 Client Credentials ---
# These are blank until you register an API client in OpenEMR.
# After first boot:
#   1. Log in at http://localhost (admin/pass)
#   2. Go to Admin > System > API Clients
#   3. Register a new client and paste the values here
#   4. Run: docker compose restart agent
OPENEMR_CLIENT_ID=
OPENEMR_CLIENT_SECRET=

# --- OpenEMR Login for Agent ---
# The agent uses these to authenticate via OAuth2 password grant.
# Defaults to admin/pass if not set.
# OPENEMR_USERNAME=admin
# OPENEMR_PASSWORD=pass
